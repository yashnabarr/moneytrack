# ── Database ──────────────────────────────────────────────────────────────────
# Append ?connection_limit=1 to avoid pool exhaustion on serverless
DATABASE_URL="mysql://user:password@host:3306/moneymint?connection_limit=1"

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET="replace-with-64-char-random-hex"
JWT_REFRESH_SECRET="replace-with-another-64-char-random-hex"

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
# Must match the redirect URI registered in Google Cloud Console
GOOGLE_CALLBACK_URL="https://your-backend.vercel.app/api/auth/google/callback"

# ── URLs ──────────────────────────────────────────────────────────────────────
# Where to redirect after Google OAuth completes
FRONTEND_URL="https://your-frontend-domain.com"
# Comma-separated list of allowed CORS origins
CORS_ORIGINS="https://your-frontend-domain.com,http://localhost:8080"

# ── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV="production"
PORT=3001
